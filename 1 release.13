cd ~/termux-tyg

mkdir -p release-1.13
cp $PREFIX/bin/bitcoind release-1.13/
cp $PREFIX/bin/bitcoin-cli release-1.13/
cp $PREFIX/bin/bitcoin-tx release-1.13/

# If you have rclone configs or scripts:
cp ~/scripts/rclone-* release-1.13/ 2>/dev/null || true
cp $PREFIX/bin/rclone release-1.13/
tar -czvf release-1.13.tar.gz release-1.13
git add release-1.13.tar.gz
git commit -m "Release 1.13: Bitcoin Core 27.0 static + rclone tools"
git tag -a v1.13 -m "Release 1.13"
git push
git push --tags
gh release create v1.13 release-1.13.tar.gz \
  --title "Release 1.13" \
  --notes "Includes Bitcoin Core 27.0 static ARM64 build and rclone utilities
  ---

